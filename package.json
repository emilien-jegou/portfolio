{
  "name": "portfolio",
  "description": "A qwik.js portfolio",
  "url": "https://emje.dev/",
  "repository": "https://github.com/emilien-jegou/portfolio",
  "engines": {
    "node": "^22"
  },
  "browserslist": [
    "baseline widely available",
    ">0.3%"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/cloudflare-pages/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "wrangler pages publish ./dist",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "dev.ts": "concurrently -n server,tsc -c magenta,cyan \"npm run dev\" \"npm run ts-watch\"",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "oxlint",
    "lint.fix": "oxlint --fix",
    "lint.watch": "oxlint --watch",
    "preview": "qwik build preview && vite preview --open",
    "serve": "wrangler pages dev ./dist",
    "start": "vite --open --mode ssr",
    "test.unit": "vitest",
    "test.unit.ui": "vitest --ui",
    "ts-watch": "tsc --noEmit --incremental --preserveWatchOutput --pretty --watch",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik-city": "^1.20.0",
    "@cloudflare/workers-types": "^4.20260601.1",
    "@modular-forms/qwik": "^0.29.1",
    "@qwikdev/pwa": "^0.0.4",
    "@svgx/vite-plugin-qwik": "^1.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-cookie": "^3.0.6",
    "@types/marked": "^6.0.0",
    "@types/matter-js": "^0.19.8",
    "@types/node": "^24.12.4",
    "@vitest/ui": "^3.2.6",
    "concurrently": "^9.2.1",
    "gray-matter": "^4.0.3",
    "jsdom": "^26.1.0",
    "oxlint": "^1.67.0",
    "prettier": "^3.8.3",
    "rehype-autolink-headings": "^7.1.0",
    "remark": "^15.0.1",
    "tailwindcss": "^4.3.0",
    "ts-essentials": "^10.2.0",
    "typescript": "^5.9.3",
    "undici": "^8.3.0",
    "unicorn": "^0.0.1",
    "vite": "^5.4.21",
    "vite-imagetools": "^7.1.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6",
    "wrangler": "^4.96.0"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.20.0",
    "@onwo/icons": "0.0.12-alpha",
    "@onwo/primitives": "0.0.12-alpha",
    "@onwo/tailwindcss": "0.0.12-alpha",
    "@onwo/ui": "0.0.12-alpha",
    "@qwik-ui/headless": "^0.6.8",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "effect": "^3.21.2",
    "ignore": "^7.0.5",
    "isomorphic-dompurify": "^3.15.0",
    "js-cookie": "^3.0.8",
    "marked": "^18.0.4",
    "matter-js": "^0.20.0",
    "npm-check-updates": "^18.3.1",
    "remeda": "^2.37.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0"
  }
}
